# ShopTalk AI Assistant - Environment Variables
# Copy this to .env and fill in your API keys
#
# RECOMMENDED: Use Ollama for local dev (free, no API key needed)
# Setup: brew install ollama, then: ollama pull llama3.2, then: ollama serve

# OpenAI API Key (optional - for GPT-4o-mini benchmark)
OPENAI_API_KEY=

# Groq API Key (optional - for Llama-3.3-70B on Kaggle, free at console.groq.com)
GROQ_API_KEY=

# ChromaDB persistence path (default: data/chroma)
CHROMA_PATH=data/chroma

# Optional: local fine-tuned SentenceTransformer path.
# Example: data/models/finetuned-shoptalk-emb
# Leave empty to use base all-MiniLM-L6-v2.
FINETUNED_MODEL_PATH=

# ElevenLabs API Key (optional, for TTS)
ELEVENLABS_API_KEY=
